
{
  "entities": {
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a single t-shirt available for sale in the mini e-commerce.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Product entity."
        },
        "slug": {
          "type": "string",
          "description": "URL-friendly identifier for the product, typically used in paths."
        },
        "name": {
          "type": "string",
          "description": "The name of the t-shirt model."
        },
        "shortDescription": {
          "type": "string",
          "description": "A brief summary or tagline for the t-shirt, displayed in product cards."
        },
        "fullDescription": {
          "type": "string",
          "description": "A detailed description of the t-shirt, including its characteristics and purpose."
        },
        "price": {
          "type": "number",
          "description": "The unit price of the t-shirt."
        },
        "imageUrls": {
          "type": "array",
          "description": "An array of URLs or paths to images of the product.",
          "items": {
            "type": "string"
          }
        },
        "availableSizes": {
          "type": "array",
          "description": "An array of strings representing the sizes available.",
          "items": {
            "type": "string"
          }
        },
        "isActive": {
          "type": "boolean",
          "description": "A boolean indicating whether the product is currently active."
        }
      },
      "required": [
        "id",
        "slug",
        "name",
        "shortDescription",
        "fullDescription",
        "price",
        "imageUrls",
        "availableSizes",
        "isActive"
      ]
    },
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "description": "Represents a customer's reservation for t-shirts.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Order."
        },
        "customerName": {
          "type": "string",
          "description": "The full name of the customer."
        },
        "customerWhatsapp": {
          "type": "string",
          "description": "The WhatsApp contact number.",
          "format": "tel"
        },
        "quantity": {
          "type": "number",
          "description": "Total number of items ordered."
        },
        "items": {
          "type": "array",
          "description": "List of specific products and sizes selected.",
          "items": {
            "type": "object",
            "properties": {
              "produto": { "type": "string" },
              "tamanho": { "type": "string" }
            }
          }
        },
        "paymentMethod": {
          "type": "string",
          "description": "Chosen payment method (e.g., 'Pix', 'Crédito')."
        },
        "totalAmount": {
          "type": "number",
          "description": "The total calculated value of the order."
        },
        "notes": {
          "type": "string",
          "description": "Customer observations."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of order creation.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "Current status (e.g., 'Pendente WhatsApp', 'Pago', 'Concluído')."
        },
        "receiptUrl": {
          "type": "string",
          "description": "URL link to the payment receipt image attached by the admin."
        }
      },
      "required": [
        "id",
        "customerName",
        "customerWhatsapp",
        "quantity",
        "items",
        "paymentMethod",
        "totalAmount",
        "createdAt",
        "status"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": {
            "$ref": "#/backend/entities/Product"
          },
          "description": "Collection storing product details.",
          "params": [
            {
              "name": "productId",
              "description": "Product ID."
            }
          ]
        }
      },
      {
        "path": "/orders/{orderId}",
        "definition": {
          "entityName": "Order",
          "schema": {
            "$ref": "#/backend/entities/Order"
          },
          "description": "Collection storing customer orders and their payment receipts.",
          "params": [
            {
              "name": "orderId",
              "description": "Order ID."
            }
          ]
        }
      }
    ]
  }
}
