rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset is designed for the "IAP Camisetas" mini e-commerce. It prioritizes 
     * a seamless shopping experience where products are globally visible and 
     * customers can place orders/reservations easily.
     */

    // --- GLOBAL HELPER FUNCTIONS ---
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the Product collection. Allows public browsing of t-shirts.
     * @path /products/{productId}
     * @allow (get/list) Any user, including unauthenticated visitors.
     * @deny (create/update/delete) Restricted to authenticated admins (future improvement).
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAuthenticated();
    }

    /**
     * @description Rules for the Order collection. 
     * @path /orders/{orderId}
     * @allow (create) Any user can create an order.
     * @allow (get/list/update) Restricted to authenticated admin users.
     * @deny (delete) Restricted to protect historical data.
     */
    match /orders/{orderId} {
      
      /**
       * Permission: Create
       * Logic: Allows order creation. Enforces that the ID in the data matches the document ID.
       */
      allow create: if request.resource.data.id == orderId;

      /**
       * Permission: Read & Update
       * Logic: Granted to authenticated users (admins) to manage the store.
       */
      allow get, list, update: if isAuthenticated();

      /**
       * Permission: Delete
       * Logic: Denied to ensure order integrity.
       */
      allow delete: if false; 
    }
  }
}