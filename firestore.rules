/**
 * IAP Camisetas - Firestore Security Rules
 * 
 * CORE PHILOSOPHY:
 * This ruleset implements a public-facing product catalog with a secure, anonymous order 
 * submission system. It prioritizes ease of use for customers while ensuring that 
 * sensitive order data is only accessible to authorized administrators.
 * 
 * DATA STRUCTURE:
 * - /products/{productId}: Publicly accessible product information.
 * - /pedidos_iap_camisetas/{orderId}: Customer orders submitted via the landing page.
 * - /roles_admin/{userId}: Internal collection for managing administrative access.
 * 
 * KEY SECURITY DECISIONS:
 * - Product Catalog: Read access is open to everyone to ensure the landing page functions 
 *   for all visitors. Writing is restricted to admins.
 * - Order Management: Any visitor (including unauthenticated ones) can create an order. 
 *   However, once created, these orders are "write-once, read-admin": they cannot be 
 *   read, listed, updated, or deleted by anyone except authenticated administrators.
 * - Administrative Roles: Admin status is verified by checking for a corresponding 
 *   document in the `/roles_admin` collection.
 * 
 * DENORMALIZATION FOR AUTHORIZATION:
 * While the current structure is simple, the rules are designed for performance. 
 * Administrative checks use the `exists()` function against a dedicated roles collection 
 * to centralize authorization logic without complicating the order or product schemas.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /**
     * @description Checks if the request is made by an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user has an entry in the admin roles collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    /**
     * @description Publicly readable collection for the product catalog. Only admins can modify products.
     * @path /products/{productId}
     * @allow (get, list) if true;
     * @deny (create, update, delete) if user is not an admin.
     * @principle Public Read with Admin-Only Writes.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Collection for customer orders. Allows anonymous creation for checkout flow.
     * @path /pedidos_iap_camisetas/{orderId}
     * @allow (create) if true; (To support anonymous customer orders).
     * @allow (get, list, update, delete) if user is an admin.
     * @deny (get, list) if user is not an admin, preventing data scraping of customer info.
     * @principle Anonymous Creation with Admin-Only Management.
     */
    match /pedidos_iap_camisetas/{orderId} {
      allow create: if true;
      allow get, list: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }

    /**
     * @description Internal collection to store administrative UIDs.
     * @path /roles_admin/{adminId}
     * @allow (get) if isSignedIn();
     * @deny (list, create, update, delete) to prevent unauthorized privilege escalation.
     * @principle Strict Role-Based Access Control.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if false;
    }
  }
}